<Window x:Class="WpfAppUI.ViewAdmin.ClientsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfAppUI.ViewAdmin"
        mc:Ignorable="d"
        Title="Клиенты" Height="450" Width="500">
    <StackPanel Background="#FFD8D8D8">
        <StackPanel Orientation="Horizontal" Background="#FFE4E0E0">
            <Button x:Name="btnEdit" Style="{StaticResource ButtonMenu}" Content="Редактировать" Command="{Binding EditClient}" Height="25"/>
            <Button x:Name="btnDelete" Style="{StaticResource ButtonMenu}" Content="Удалить" Command="{Binding DeleteClient}" Height="25"/>
        </StackPanel>
        <Label Margin="5" HorizontalAlignment="Center">Список клиентов</Label>
        <ListView Height="300" x:Name="lvRole" ItemsSource="{Binding ListClient}" SelectedItem="{Binding SelectedClient, Mode=TwoWay}" Background="#FFD3CDCD">
            <ListView.View >
                <GridView>
                    <GridView.Columns>
                        <GridViewColumn Header="Id" Width="50" DisplayMemberBinding="{Binding Id}"/>
                        <GridViewColumn Header="UserId" DisplayMemberBinding="{Binding UserId}"/>
                        <GridViewColumn Header="FullName" DisplayMemberBinding="{Binding FullName}"/>
                        <GridViewColumn Header="Phone" DisplayMemberBinding="{Binding Phone}"/>
                        <GridViewColumn Header="Balance" DisplayMemberBinding="{Binding Balance}"/>
                    </GridView.Columns>
                </GridView>
            </ListView.View>
        </ListView>
    </StackPanel>
</Window>
