<Window x:Class="WpfAppUI.HistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="История аренд" Height="500" Width="800"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="60"/>
            <!-- Увеличил высоту для кнопок -->
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" 
                   Text="История моих аренд" 
                   FontSize="20" 
                   FontWeight="Bold"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Center"/>

        <DataGrid Grid.Row="1" 
                  x:Name="dgHistory"
                  ItemsSource="{Binding ListRental}"
                  SelectedItem="{Binding SelectedRental}" 
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  Margin="0,10,0,0">
            <!-- SelectedItem выше очень важен, чтобы команда понимала, что удалять -->

            <DataGrid.Columns>
                <DataGridTextColumn Header="Начало" 
                                    Binding="{Binding StartTime, StringFormat='dd.MM.yyyy HH:mm'}"
                                    Width="130"/>

                <DataGridTextColumn Header="Окончание" 
                                    Binding="{Binding EndTime, StringFormat='dd.MM.yyyy HH:mm', TargetNullValue='Активна'}"
                                    Width="130"/>

                <DataGridTextColumn Header="Велосипед" 
                                    Binding="{Binding Bicycle.Model}"
                                    Width="*"/>

                <DataGridTextColumn Header="Тариф" 
                                    Binding="{Binding Tariff.PricePerHour}"
                                    Width="100"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Нижняя панель с кнопками -->
        <StackPanel Grid.Row="2" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Center" 
                    VerticalAlignment="Center">

            <Button Content="Отменить аренду" 
                    Command="{Binding CancelRental}"
                    Width="150" Height="35"
                    Margin="10,0"
                    Background="#FFFFE1E1"/>
            <!-- Нежно-красный цвет для привлечения внимания -->

            <Button Content="Закрыть" 
                    Width="100" Height="35"
                    HorizontalAlignment="Center"
                    Click="Close_Click"
                    Margin="10,0"/>
        </StackPanel>
    </Grid>
</Window>