<Window x:Class="WpfAppUI.AdminWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfAppUI"
        mc:Ignorable="d"
        Title="Админ-панель" Height="300" Width="300"
        ResizeMode="NoResize">
    <Grid>
        <Menu>
            <MenuItem x:Name="Bicycle" Header="Велосипеды" Click="Bicycle_Click"></MenuItem>
            <MenuItem x:Name="Client" Header="Клиенты" Click="Client_Click"></MenuItem>
            <MenuItem x:Name="Rental" Header="Аренды" Click="Rental_Click"></MenuItem>
            <MenuItem x:Name="Station" Header="Станции" Click="Station_Click"></MenuItem>
            <MenuItem x:Name="Tariff" Header="Тарифы" Click="Tariff_Click"></MenuItem>
            <MenuItem x:Name="User" Header="Пользователи" Click="User_Click"></MenuItem>
            <MenuItem x:Name="Exit" Header="Выход" Click="Exit_Click"></MenuItem>
        </Menu>
    </Grid>
</Window>
