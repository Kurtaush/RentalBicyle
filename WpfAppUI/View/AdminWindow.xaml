<Window x:Class="WpfAppUI.AdminWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfAppUI"
        mc:Ignorable="d"
        Title="AdminWindow" Height="450" Width="800">
    <Grid>
        <Menu>
            <MenuItem x:Name="Bicycle" Header="Велосипеды"></MenuItem>
            <MenuItem x:Name="Client" Header="Клиенты"></MenuItem>
            <MenuItem x:Name="Payment" Header="Платежи"></MenuItem>
            <MenuItem x:Name="Rental" Header="Аренды"></MenuItem>
            <MenuItem x:Name="Station" Header="Станции"></MenuItem>
            <MenuItem x:Name="Tariff" Header="Тарифы"></MenuItem>
            <MenuItem x:Name="User" Header="Пользователи"></MenuItem>
        </Menu>
    </Grid>
</Window>
