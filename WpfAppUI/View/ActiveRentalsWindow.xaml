<Window x:Class="WpfAppUI.View.ActiveRentalsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfAppUI.View"
        mc:Ignorable="d"
        Title="Активные аренды" Height="450" Width="900">
    <StackPanel Background="#FFD8D8D8">
        <StackPanel Orientation="Horizontal" Background="#FFE4E0E0">
            <Button x:Name="btnEmergencyClose" Content="Экстренно завершить" 
                    Style="{StaticResource ButtonMenu}" Command="{Binding EmergencyCloseCommand}" Height="25"/>
        </StackPanel>
        <Label Margin="5" HorizontalAlignment="Center" FontWeight="Bold">Список активных аренд</Label>
        <ListView Height="300" ItemsSource="{Binding ActiveRentals}" 
                  SelectedItem="{Binding SelectedRental, Mode=TwoWay}" Background="#FFD3CDCD">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Id" Width="40" DisplayMemberBinding="{Binding Id}"/>
                    <GridViewColumn Header="Клиент" Width="150" DisplayMemberBinding="{Binding Client.FullName}"/>
                    <GridViewColumn Header="Телефон" Width="120" DisplayMemberBinding="{Binding Client.Phone}"/>
                    <GridViewColumn Header="Велосипед" Width="120" DisplayMemberBinding="{Binding Bicycle.Model}"/>
                    <GridViewColumn Header="Станция начала" Width="120" DisplayMemberBinding="{Binding StartStation.Name}"/>
                    <GridViewColumn Header="Начало аренды" Width="130" DisplayMemberBinding="{Binding StartTime, StringFormat=dd.MM.yyyy HH:mm}"/>
                    <GridViewColumn Header="Тариф" Width="80" DisplayMemberBinding="{Binding Tariff.Name}"/>
                </GridView>
            </ListView.View>
        </ListView>
    </StackPanel>
</Window>