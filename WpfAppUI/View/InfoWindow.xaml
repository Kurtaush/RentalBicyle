<Window x:Class="WpfAppUI.View.InfoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfAppUI.View"
        mc:Ignorable="d"
        
        Title="Личные данные" Height="160" Width="300">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40*"/>
            <RowDefinition Height="40*"/>
            <RowDefinition Height="50*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="40*"/>
            <ColumnDefinition Width="75*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Text="Имя:" Grid.Column="0" Style="{StaticResource crudTextBlock}"/>
        <TextBlock Grid.Row="1" Text="Номер:" Grid.Column="0" Style="{StaticResource crudTextBlock}"/>

        <TextBox x:Name="NameText" MaxLength="45" Grid.Row="0" Grid.Column="1" Style="{StaticResource crudTextBox}" AutomationProperties.Name="LoginText"/>
        <TextBox x:Name="PhoneText" MaxLength="30" Grid.Row="1" Grid.Column="1" Style="{StaticResource crudTextBox}" AutomationProperties.Name="LoginText"/>

        <Button Click="SaveInfo_Click" Cursor="Hand" Grid.Row="2" Grid.ColumnSpan="2" Width="80" Height="25" Content="Сохранить"/>
    </Grid>
</Window>
