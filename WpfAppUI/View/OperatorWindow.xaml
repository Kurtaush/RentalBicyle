<Window x:Class="WpfAppUI.View.OperatorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfAppUI.View"
        mc:Ignorable="d"
        Title="Управление велосипедами на станции" Height="450" Width="700">
    <StackPanel Background="#FFD8D8D8">
        <Label x:Name="lblStationName" Margin="5" HorizontalAlignment="Center" FontWeight="Bold" FontSize="14"/>
        <StackPanel Orientation="Horizontal" Background="#FFE4E0E0">
            <Button x:Name="btnSetMaintenance" Content="На обслуживание" 
                    Style="{StaticResource ButtonMenu}" Command="{Binding SetMaintenanceCommand}" Height="25"/>
            <Button x:Name="btnSetFree" Content="Сделать свободным" 
                    Style="{StaticResource ButtonMenu}" Command="{Binding SetFreeCommand}" Height="25"/>
        </StackPanel>
        <Label Margin="5" HorizontalAlignment="Center">Список велосипедов на станции (свободные и на обслуживании)</Label>
        <ListView Height="300" ItemsSource="{Binding Bicycles}" 
                  SelectedItem="{Binding SelectedBicycle, Mode=TwoWay}" Background="#FFD3CDCD">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Id" Width="50" DisplayMemberBinding="{Binding Id}"/>
                    <GridViewColumn Header="Модель" Width="150" DisplayMemberBinding="{Binding Model}"/>
                    <GridViewColumn Header="Статус" Width="100" DisplayMemberBinding="{Binding Status}"/>
                    <GridViewColumn Header="Тариф" Width="100" DisplayMemberBinding="{Binding Tariff.Name}"/>
                </GridView>
            </ListView.View>
        </ListView>
    </StackPanel>
</Window>